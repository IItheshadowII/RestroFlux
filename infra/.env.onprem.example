# Archivo legacy para instalaciones on-premise antiguas.
# El flujo recomendado actual es usar .env.example -> .env.local
# junto con docker-compose.local.yml e install-local.*

APP_MODE=LOCAL
NODE_ENV=production
APP_HTTP_PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

RESTROFLUX_IMAGE=ghcr.io/iitheshadowii/restroflux-app:latest
MINIO_IMAGE=minio/minio:latest

DATABASE_URL=
DB_HOST=restroflux-postgres
DB_PORT=5432
DB_NAME=restroflux
DB_USER=restroflux
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false

POSTGRES_DB=restroflux
POSTGRES_USER=restroflux
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA
POSTGRES_PORT=5432

STORAGE_TYPE=local
MINIO_ENDPOINT=restroflux-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CAMBIAR_POR_PASSWORD_SEGURA
MINIO_BUCKET=restroflux
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

JWT_SECRET=CAMBIAR_POR_CLAVE_SEGURA
MULTI_TENANT_ENFORCE_AUTH=true
SMTP_FROM=RestroFlux <no-reply@example.invalid>

VITE_APP_MODE=CLOUD
VITE_API_URL=/api
VITE_CLOUD_URL=
VITE_LICENSE_KEY=
VITE_INSTANCE_ID=
VITE_LICENSE_CHECK_INTERVAL_DAYS=1
VITE_LICENSE_GRACE_DAYS=7
