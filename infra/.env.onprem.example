# Variables de entorno para despliegue on-premise.
# Este archivo se pasa a docker compose con --env-file y no se sube al repo.

# Build del frontend
VITE_APP_MODE=LOCAL
VITE_API_URL=/api
VITE_LICENSE_KEY=RF-XXXX-XXXX-XXXX
VITE_INSTANCE_ID=restroflux-local-001
VITE_LICENSE_CHECK_INTERVAL_DAYS=1
VITE_LICENSE_GRACE_DAYS=7
VITE_CLOUD_URL=https://app.restroflux.example.com

# App
NODE_ENV=production
PUBLIC_BASE_URL=http://localhost:3000

# Database
DB_HOST=restroflux-postgres
DB_PORT=5432
DB_NAME=restroflux
DB_USER=restroflux
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA
# DATABASE_URL=postgresql://restroflux:CAMBIAR_POR_PASSWORD_SEGURA@restroflux-postgres:5432/restroflux
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Seguridad
JWT_SECRET=CAMBIAR_POR_CLAVE_SEGURA
MULTI_TENANT_ENFORCE_AUTH=true

# Almacenamiento
STORAGE_TYPE=local
MINIO_ENDPOINT=restroflux-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CAMBIAR_POR_PASSWORD_SEGURA
MINIO_BUCKET=restroflux

# Telemetría
ENABLE_TELEMETRY=false

# Otros
SMTP_FROM=RestroFlux <no-reply@restroflux.local>
PORT=3000
