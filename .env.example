# ====================================
# RestroFlux - Variables de entorno de ejemplo
# ====================================
# Este archivo NO se monta automáticamente en Portainer Repository.
# Úsalo como referencia para cargar variables en Portainer o para un .env local fuera del repo.

# ------------------------------------
# Build del frontend (no secretos)
# ------------------------------------
VITE_APP_MODE=CLOUD
VITE_API_URL=/api
VITE_CLOUD_URL=https://app.restroflux.example.com
# VITE_LICENSE_KEY=RF-XXXX-XXXX-XXXX
# VITE_INSTANCE_ID=restroflux-instance-001
VITE_LICENSE_CHECK_INTERVAL_DAYS=1
VITE_LICENSE_GRACE_DAYS=7

# ------------------------------------
# Runtime de la app
# ------------------------------------
NODE_ENV=production
APP_PORT=3000
PUBLIC_BASE_URL=https://app.restroflux.example.com

# ------------------------------------
# PostgreSQL interno del stack
# Si defines DATABASE_URL, tiene prioridad sobre DB_*
# El hostname debe coincidir con el servicio del compose/stack: restroflux-postgres
# ------------------------------------
DB_HOST=restroflux-postgres
DB_PORT=5432
DB_NAME=restroflux
DB_USER=restroflux
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA
# DATABASE_URL=postgresql://restroflux:CAMBIAR_POR_PASSWORD_SEGURA@restroflux-postgres:5432/restroflux
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# ------------------------------------
# Seguridad
# ------------------------------------
JWT_SECRET=CAMBIAR_POR_CLAVE_SEGURA_DE_32_CARACTERES_MINIMO
GLOBAL_ADMIN_BOOTSTRAP_TOKEN=
MULTI_TENANT_ENFORCE_AUTH=true

# ------------------------------------
# SMTP (opcional)
# ------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=RestroFlux <no-reply@restroflux.example.com>

# ------------------------------------
# Mercado Pago (opcional)
# ------------------------------------
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ------------------------------------
# Gemini / IA (opcional)
# ------------------------------------
GEMINI_API_KEY=

# ------------------------------------
# MinIO (opcional)
# ------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA

# ------------------------------------
# Swarm / stack preconstruida (opcional)
# ------------------------------------
# RESTROFLUX_IMAGE=ghcr.io/tu-organizacion/restroflux:latest
