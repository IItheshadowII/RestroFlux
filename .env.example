# ====================================
# RestroFlux - Variables de entorno de ejemplo
# ====================================
# Usa este archivo como plantilla:
# - Cloud/demo: cárgalo como referencia en Portainer o Docker Swarm.
# - Local/on-premise: cópialo a .env.local y ajusta los valores.

# ------------------------------------
# Modo de despliegue
# ------------------------------------
# LOCAL = instalación en servidor del cliente.
# CLOUD = demo / infraestructura pública.
APP_MODE=LOCAL
NODE_ENV=production

# ------------------------------------
# App / HTTP
# ------------------------------------
APP_HTTP_PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# ------------------------------------
# Frontend compilado
# La imagen publicada en GHCR ya sale compilada en modo API (/api).
# Solo ajusta estos valores si vas a construir una imagen propia.
# ------------------------------------
VITE_APP_MODE=CLOUD
VITE_API_URL=/api
VITE_CLOUD_URL=
VITE_LICENSE_KEY=
VITE_INSTANCE_ID=
VITE_LICENSE_CHECK_INTERVAL_DAYS=1
VITE_LICENSE_GRACE_DAYS=7

# ------------------------------------
# Imagenes Docker
# ------------------------------------
RESTROFLUX_IMAGE=ghcr.io/iitheshadowii/restroflux-app:latest
MINIO_IMAGE=minio/minio:latest

# ------------------------------------
# Base de datos app
# Si defines DATABASE_URL, tiene prioridad sobre DB_*
# ------------------------------------
DATABASE_URL=
DB_HOST=restroflux-postgres
DB_PORT=5432
DB_NAME=restroflux
DB_USER=restroflux
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# ------------------------------------
# PostgreSQL del contenedor
# Mantén estos valores alineados con DB_NAME/DB_USER/DB_PASSWORD
# ------------------------------------
POSTGRES_DB=restroflux
POSTGRES_USER=restroflux
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA
POSTGRES_PORT=5432

# ------------------------------------
# MinIO / almacenamiento
# Hoy es opcional en la app, pero queda listo para despliegues futuros.
# ------------------------------------
STORAGE_TYPE=local
MINIO_ENDPOINT=restroflux-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CAMBIAR_POR_PASSWORD_SEGURA
MINIO_BUCKET=restroflux
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ------------------------------------
# Seguridad / autenticación
# ------------------------------------
JWT_SECRET=CAMBIAR_POR_CLAVE_SEGURA_DE_32_CARACTERES_MINIMO
GLOBAL_ADMIN_BOOTSTRAP_TOKEN=
MULTI_TENANT_ENFORCE_AUTH=true

# ------------------------------------
# Email / SMTP
# ------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=RestroFlux <no-reply@example.invalid>

# ------------------------------------
# Integraciones externas
# ------------------------------------
GEMINI_API_KEY=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
